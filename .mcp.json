{
  "mcpServers": {
    "github": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "command": "npx",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "graphify": {
      "args": [
        "-m",
        "graphify.serve",
        "/home/anthony/Documents/perso/projects/chrysa/project-init/graphify-out/graph.json"
      ],
      "command": "python3"
    },
    "notion": {
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "command": "npx",
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\": \"Bearer ${NOTION_API_KEY}\", \"Notion-Version\": \"2022-06-28\"}"
      }
    }
  }
}
